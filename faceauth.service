[Unit]
Description=AegisFace - C++ Background Face ID Service
After=multi-user.target

[Service]
Type=simple
User=ads
RuntimeDirectory=faceauth
RuntimeDirectoryMode=0755
WorkingDirectory=/home/ads/Antigravity/Projeler/AegisFace
ExecStart=/home/ads/Antigravity/Projeler/AegisFace/build/faceauth_daemon
Restart=always
RestartSec=2
StandardOutput=journal
StandardError=journal
SyslogIdentifier=faceauth-daemon

[Install]
WantedBy=multi-user.target
