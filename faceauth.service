[Unit]
Description=FaceAuth NextGen - C++ Arkaplan Yuz Tanima Servisi
After=multi-user.target

[Service]
Type=simple
User=ads
RuntimeDirectory=faceauth
RuntimeDirectoryMode=0755
WorkingDirectory=/home/ads/Antigravity/Projeler/FaceAuth_NextGen
ExecStart=/home/ads/Antigravity/Projeler/FaceAuth_NextGen/build/faceauth_daemon
Restart=always
RestartSec=2
StandardOutput=journal
StandardError=journal
SyslogIdentifier=faceauth-daemon

[Install]
WantedBy=multi-user.target
